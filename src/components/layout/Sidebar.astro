---
import { allPatterns } from '../../data/patterns';
import { categories, categoryPatterns } from '../../data/navigation';

const currentPath = Astro.url.pathname;
const currentSlug = currentPath.replace('/patterns/', '').replace(/\/$/, '');

const catMeta: Record<string, { color: string; lightColor: string }> = {
  creational: { color: '#8b5cf6', lightColor: 'rgba(139, 92, 246, 0.1)' },
  structural: { color: '#06b6d4', lightColor: 'rgba(6, 182, 212, 0.1)' },
  behavioral: { color: '#f59e0b', lightColor: 'rgba(245, 158, 11, 0.1)' },
  'data-access': { color: '#10b981', lightColor: 'rgba(16, 185, 129, 0.1)' },
};
---

<aside id="sidebar" class="fixed top-0 left-0 z-40 w-[272px] h-screen overflow-y-auto scrollbar-thin hidden lg:flex flex-col border-r border-gray-200/50 dark:border-white/[0.04] bg-white/80 dark:bg-surface-1/90 backdrop-blur-xl">
  <!-- Logo -->
  <div class="sidebar-logo-area">
    <a href="/" class="flex items-center gap-3 group">
      <div class="sidebar-logo-mark">
        <svg width="20" height="20" viewBox="0 0 32 32" fill="none">
          <!-- Diamond / pattern motif -->
          <rect x="4" y="4" width="10" height="10" rx="2.5" fill="white" opacity="0.9"/>
          <rect x="18" y="4" width="10" height="10" rx="2.5" fill="white" opacity="0.6"/>
          <rect x="4" y="18" width="10" height="10" rx="2.5" fill="white" opacity="0.6"/>
          <rect x="18" y="18" width="10" height="10" rx="2.5" fill="white" opacity="0.35"/>
        </svg>
      </div>
      <div>
        <span class="text-[15px] font-bold text-gray-900 dark:text-white tracking-tight group-hover:text-[#8b5cf6] dark:group-hover:text-[#a78bfa] transition-colors">Design Patterns</span>
        <span class="block text-[10px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-[0.14em]">Interactive Guide</span>
      </div>
    </a>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-4 space-y-5 overflow-y-auto scrollbar-thin">
    {Object.entries(categories).map(([catId, cat]) => {
      const meta = catMeta[catId];
      const slugs = categoryPatterns[catId] || [];
      const isActiveCat = currentPath === cat.slug || currentPath === `${cat.slug}/`;
      const hasCategoryMatch = slugs.includes(currentSlug);

      return (
        <div>
          <a
            href={cat.slug}
            class={`sidebar-cat-header ${isActiveCat || hasCategoryMatch ? 'active' : ''}`}
            style={isActiveCat || hasCategoryMatch ? `--cat-color: ${meta.color};` : `--cat-color: ${meta.color};`}
          >
            <span class="flex items-center gap-2.5">
              <span class="sidebar-cat-icon" style={`--icon-color: ${meta.color};`}>
                {catId === 'creational' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                  </svg>
                )}
                {catId === 'structural' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7" rx="1"/>
                    <rect x="14" y="3" width="7" height="7" rx="1"/>
                    <rect x="3" y="14" width="7" height="7" rx="1"/>
                    <rect x="14" y="14" width="7" height="7" rx="1"/>
                    <line x1="10" y1="6.5" x2="14" y2="6.5"/>
                    <line x1="6.5" y1="10" x2="6.5" y2="14"/>
                  </svg>
                )}
                {catId === 'behavioral' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                  </svg>
                )}
                {catId === 'data-access' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <ellipse cx="12" cy="5" rx="9" ry="3"/>
                    <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                    <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                  </svg>
                )}
              </span>
              {cat.name}
            </span>
            <span class={`sidebar-cat-count ${isActiveCat || hasCategoryMatch ? 'active' : ''}`}>{slugs.length}</span>
          </a>
          <ul class="mt-1 space-y-0.5">
            {slugs.map(slug => {
              const pattern = allPatterns.find(p => p.slug === slug);
              if (!pattern) return null;
              const isActive = currentSlug === slug;
              return (
                <li>
                  <a
                    href={`/patterns/${slug}`}
                    class={`group flex items-center gap-2.5 px-3 py-[7px] text-[13px] rounded-lg transition-all duration-200 ${
                      isActive
                        ? 'font-semibold text-gray-900 dark:text-white bg-gray-100 dark:bg-white/[0.06]'
                        : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100/60 dark:hover:bg-white/[0.04]'
                    }`}
                  >
                    <span
                      class={`w-1.5 h-1.5 rounded-full flex-shrink-0 transition-all duration-200 ${
                        isActive ? 'scale-125' : 'scale-75 opacity-40 group-hover:opacity-70 group-hover:scale-100'
                      }`}
                      style={`background: ${meta.color}`}
                    ></span>
                    {pattern.name}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      );
    })}
  </nav>

  <!-- Footer -->
  <div class="px-4 py-4 border-t border-gray-200/50 dark:border-white/[0.04]">
    <div class="text-[10px] text-gray-400 dark:text-gray-600 text-center">
      🍔 All examples use a burger restaurant theme
    </div>
  </div>
</aside>

<style>
  .sidebar-logo-area {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 22px 16px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  }
  :global(.dark) .sidebar-logo-area {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .sidebar-logo-mark {
    width: 38px;
    height: 38px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #8b5cf6 0%, #06b6d4 100%);
    box-shadow: 0 4px 14px rgba(139, 92, 246, 0.25);
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
  }
  a:hover .sidebar-logo-mark {
    transform: scale(1.06) rotate(-2deg);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.35);
  }

  .sidebar-cat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b7280;
    transition: all 0.2s ease;
  }
  :global(.dark) .sidebar-cat-header {
    color: #9ca3af;
  }
  .sidebar-cat-header:hover {
    background: rgba(0, 0, 0, 0.03);
  }
  :global(.dark) .sidebar-cat-header:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .sidebar-cat-header.active {
    color: white;
    background: var(--cat-color);
  }

  .sidebar-cat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--icon-color);
    opacity: 0.8;
    transition: transform 0.2s ease;
  }
  .sidebar-cat-header:hover .sidebar-cat-icon {
    transform: scale(1.1);
  }
  .sidebar-cat-header.active .sidebar-cat-icon {
    color: white;
    opacity: 1;
  }

  .sidebar-cat-count {
    font-size: 10px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: #9ca3af;
    background: rgba(0, 0, 0, 0.04);
    padding: 1px 7px;
    border-radius: 100px;
  }
  :global(.dark) .sidebar-cat-count {
    color: #6b7280;
    background: rgba(255, 255, 255, 0.06);
  }
  .sidebar-cat-count.active {
    color: white;
    background: rgba(255, 255, 255, 0.2);
  }
</style>
