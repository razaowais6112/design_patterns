---
import type { PatternData } from '../../data/types';

export interface Props {
  pattern: PatternData;
}

const { pattern } = Astro.props;

const categoryMeta: Record<string, { color: string; glow: string; bgLight: string; bgDark: string }> = {
  creational: {
    color: '#8b5cf6',
    glow: 'rgba(139, 92, 246, 0.12)',
    bgLight: 'rgba(139, 92, 246, 0.06)',
    bgDark: 'rgba(139, 92, 246, 0.08)',
  },
  structural: {
    color: '#06b6d4',
    glow: 'rgba(6, 182, 212, 0.12)',
    bgLight: 'rgba(6, 182, 212, 0.06)',
    bgDark: 'rgba(6, 182, 212, 0.08)',
  },
  behavioral: {
    color: '#f59e0b',
    glow: 'rgba(245, 158, 11, 0.12)',
    bgLight: 'rgba(245, 158, 11, 0.06)',
    bgDark: 'rgba(245, 158, 11, 0.08)',
  },
  'data-access': {
    color: '#10b981',
    glow: 'rgba(16, 185, 129, 0.12)',
    bgLight: 'rgba(16, 185, 129, 0.06)',
    bgDark: 'rgba(16, 185, 129, 0.08)',
  },
};

const meta = categoryMeta[pattern.category.id] || categoryMeta.creational;
const iconSrc = `/icons/${pattern.slug}.png`;
---

<a
  href={`/patterns/${pattern.slug}`}
  class="pattern-card group relative block rounded-2xl overflow-hidden transition-all duration-300"
  style={`--card-color: ${meta.color}; --card-glow: ${meta.glow};`}
>
  <!-- Gradient top strip -->
  <div class="h-1 w-full" style={`background: ${meta.color};`}></div>

  <div class="p-5">
    <div class="flex items-start justify-between mb-3">
      <!-- Pattern illustration -->
      <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 transition-all duration-300 group-hover:scale-110">
        <img src={iconSrc} alt={`${pattern.name} pattern illustration`} width="56" height="56" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <!-- Category label -->
      <span class="text-[10px] font-semibold uppercase tracking-wider px-2 py-1 rounded-md"
        style={`color: ${meta.color}; background: ${meta.bgLight};`}
      >{pattern.category.name}</span>
    </div>

    <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1.5 group-hover:text-[var(--card-color)] transition-colors">
      {pattern.name}
    </h3>
    <p class="text-[13px] text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2">{pattern.intent}</p>

    <!-- Arrow indicator -->
    <div class="flex items-center gap-1 mt-3 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-300"
      style={`color: ${meta.color};`}
    >
      <span>Explore</span>
      <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>

<style>
  .pattern-card {
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(0, 0, 0, 0.06);
    backdrop-filter: blur(8px);
  }

  :global(.dark) .pattern-card {
    background: rgba(26, 26, 37, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.04);
  }

  .pattern-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px var(--card-glow), 0 4px 16px rgba(0, 0, 0, 0.06);
    border-color: var(--card-color);
  }

  :global(.dark) .pattern-card:hover {
    background: rgba(26, 26, 37, 0.8);
    box-shadow: 0 12px 32px var(--card-glow), 0 4px 16px rgba(0, 0, 0, 0.2);
    border-color: color-mix(in srgb, var(--card-color) 40%, transparent);
  }
</style>
