---
import '../styles/global.css';
import Sidebar from '../components/layout/Sidebar.astro';
import Header from '../components/layout/Header.astro';

export interface Props {
  title: string;
  description?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
}

const { title, description, breadcrumbs } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Design Patterns</title>
    <meta name="description" content={description || 'Learn software design patterns through interactive examples with a burger restaurant theme'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      // Dark mode initialization — runs before paint to prevent flash
      if (localStorage.getItem('theme') === 'light') {
        document.documentElement.classList.remove('dark');
      } else if (localStorage.getItem('theme') === 'dark' || !localStorage.getItem('theme')) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen antialiased relative">
    <!-- Background mesh gradient -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 -left-40 w-80 h-80 rounded-full opacity-[0.03] dark:opacity-[0.04] blur-[100px]" style="background: #8b5cf6;"></div>
      <div class="absolute top-1/3 -right-40 w-96 h-96 rounded-full opacity-[0.03] dark:opacity-[0.04] blur-[100px]" style="background: #06b6d4;"></div>
      <div class="absolute bottom-0 left-1/3 w-80 h-80 rounded-full opacity-[0.02] dark:opacity-[0.03] blur-[100px]" style="background: #f59e0b;"></div>
    </div>

    <div class="flex">
      <Sidebar />
      <div class="flex-1 min-w-0 lg:ml-[272px]">
        <Header title={title} breadcrumbs={breadcrumbs} />
        <main class="px-4 sm:px-6 lg:px-10 py-8 max-w-[900px] mx-auto">
          <slot />
        </main>
        <footer class="border-t border-gray-200/50 dark:border-white/[0.04] px-4 sm:px-6 lg:px-10 py-8 max-w-[900px] mx-auto">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500 dark:text-gray-500">
            <div class="flex items-center gap-2">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-brand-500">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" fill="currentColor"/>
              </svg>
              <span>Design Patterns — 10 patterns across 4 categories</span>
            </div>
            <p>Built with ❤️ for learning.</p>
          </div>
        </footer>
      </div>
    </div>
  </body>
</html>
